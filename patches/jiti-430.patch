From c76aa48bf822f46551248bf458585a3f9ca784f6 Mon Sep 17 00:00:00 2001
From: Pooya Parsa <pooya@pi0.io>
Date: Fri, 27 Feb 2026 14:53:13 +0100
Subject: [PATCH] feat: add `jiti/static` export

Static import of babel.cjs for Bun compiled binary support.

Co-authored-by: Mario Zechner <badlogicgames@gmail.com>
---
 lib/jiti-static.mjs | 23 +++++++++++++++++++++++
 package.json        |  7 +++++++
 2 files changed, 30 insertions(+)
 create mode 100644 lib/jiti-static.mjs

diff --git a/lib/jiti-static.mjs b/lib/jiti-static.mjs
new file mode 100644
index 00000000..d2b0417e
--- /dev/null
+++ b/lib/jiti-static.mjs
@@ -0,0 +1,23 @@
+import { createRequire } from "node:module";
+import _createJiti from "../dist/jiti.cjs";
+// Static import so Bun bundles babel.cjs into compiled binaries
+import _babelTransform from "../dist/babel.cjs";
+
+function onError(err) {
+  throw err; /* ↓ Check stack trace ↓ */
+}
+
+const nativeImport = (id) => import(id);
+
+export function createJiti(id, opts = {}) {
+  if (!opts.transform) {
+    opts = { ...opts, transform: _babelTransform };
+  }
+  return _createJiti(id, opts, {
+    onError,
+    nativeImport,
+    createRequire,
+  });
+}
+
+export default createJiti;
diff --git a/package.json b/package.json
index 71ac3bb2..696a11b0 100644
--- a/package.json
+++ b/package.json
@@ -24,6 +24,10 @@
       "types": "./lib/jiti.d.mts",
       "import": "./lib/jiti-native.mjs"
     },
+    "./static": {
+      "types": "./lib/jiti.d.mts",
+      "import": "./lib/jiti-static.mjs"
+    },
     "./package.json": "./package.json"
   },
   "main": "./lib/jiti.cjs",
@@ -36,6 +40,9 @@
       ],
       "native": [
         "./lib/jiti.d.mts"
+      ],
+      "static": [
+        "./lib/jiti.d.mts"
       ]
     }
   },
